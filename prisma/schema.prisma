generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Sponsor {
  id                String         @id @default(uuid())
  nome              String
  empresa           String
  whatsapp          String
  areas_contratadas String[]
  data_limite       DateTime
  avisou_time       Boolean        @default(false)

  // Briefing context — pre-filled by PM from commercial meeting
  briefing_areas     String?
  briefing_systems   String?
  briefing_ai_usage  String?

  // Sponsor diagnostic form — filled by CEO
  form_status        String    @default("pending")
  form_responses     Json      @default("{}")
  form_started_at    DateTime?
  form_completed_at  DateTime?

  entrevistados     Entrevistado[]
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  @@map("sponsors")
}

model Entrevistado {
  id                   String    @id @default(uuid())
  sponsor_id           String
  sponsor              Sponsor   @relation(fields: [sponsor_id], references: [id], onDelete: Cascade)

  nome                 String
  cargo                String
  area                 String
  whatsapp             String    @unique

  tipo                 String    @default("operador") // "gestor" | "operador"

  status               String    @default("nao_iniciado")
  secao_atual          Int       @default(1)
  secoes_completadas   Int[]     @default([])

  respostas            Json      @default("{}")

  iniciado_em          DateTime?
  concluido_em         DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  @@map("entrevistados")
  @@index([sponsor_id])
  @@index([status])
}
